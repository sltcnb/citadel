    print("      Best for: development, CI pipelines, offline labs")
    print("      Requires: Docker")
    print()
    print(f"  {BOLD}[s]{RESET}  Status    — check what is currently running")
    print(f"  {BOLD}[c]{RESET}  Config    — show current configuration")
    print(f"  {BOLD}[q]{RESET}  Quit")
    print()
    choice = input("  Choice [1/2/3/s/c/q]: ").strip()
    if choice == "1":
        deploy_docker()
    elif choice == "2":
        cfg = load_config()
        _deploy_k8s_flow(cfg)
    elif choice == "3":
        cfg = load_config()
        ensure_k3d()
        create_k3d_cluster(cfg)
        _deploy_k8s_flow(cfg)
    elif choice in ("s", "S"):
        load_config()
        mode = _detect_mode()
        if mode == "docker":
            cmd_status_docker()
        elif mode == "k8s":
            cmd_status_k8s()
        elif mode == "helm":
            cmd_status_helm(load_config())
        else:
            die("No active deployment detected.")
    elif choice in ("c", "C"):
        cmd_config()
    elif choice in ("q", "Q"):
        sys.exit(0)
    else:
        die(f"Invalid choice: '{choice}'")


# ── k8s deploy flow ───────────────────────────────────────────────────────────

def _deploy_k8s_flow(cfg, no_build=False, no_cache=False, restart=False,
                     setup_traefik=False):
    if restart:
        no_build = True

    mode = "Restart-only" if restart else ("No-build" if no_build else "Full")
    print(f"\n  Citadel — Deploying ({mode})\n")
    info(f"Context  : {cfg['cluster'].get('context') or '(current)'}")
    info(f"Hostname : {cfg['access']['hostname']}")
    info(f"Registry : {cfg['images']['registry'] or '(none — direct load)'}")
    _heap = {**auto_resources(), **cfg.get("resources", {})}.get("elasticsearch_heap_mb", 512)
    info(f"ES heap  : {_heap} MB (auto-sized; override via config.json resources)")
    info(f"\n  ⚠️  This script will NOT touch:")
    info("     - analyse namespace (CoreDNS, Bloodhound, etc.)")
    info("     - kube-system namespace (Traefik, k3s system)")
    info("     - tailscale namespace")
    info(f"     Only {NS} namespace will be modified.\n")

    if not no_build:
        if not cmd_exists("docker"):
            die("Docker not found. Install Docker Desktop or the Docker CLI.")
        if run(["docker", "info"], capture=True, check=False).returncode != 0:
            die("Docker daemon is not running.")
        ok("Docker is running")

    # Pull latest submodule content (plugins, modules, collector, alert_rules).
    # sync first so .git/config reflects any URL changes in .gitmodules.
    step("Updating git submodules")
    run(["git", "submodule", "sync", "--recursive"], capture=True, check=False)
    r = run(["git", "submodule", "update", "--init", "--recursive"], capture=True, check=False)
    if r.returncode == 0:
        ok("Submodules up to date")
    else:
        warn("git submodule update failed — build may use stale submodule content\n" + (r.stderr or ""))

    setup_cluster(cfg)

    if not no_build:
        build_images(cfg, no_cache=no_cache)

    pull_policy = "IfNotPresent" if cfg["images"]["registry"] else "Never"
    if not no_build:
        pull_policy = load_images(cfg)
    else:
        ok("Skipping image load (--no-build)")

    _ensure_namespace()
    setup_tls_secret(cfg)
    cleanup_stale_resources()

    step("Checking VPA controller")
    ensure_vpa_controller()

    apply_all_manifests(cfg, pull_policy, setup_traefik=setup_traefik)
    wait_for_elasticsearch()
    apply_es_template()
    rollout_restart_apps()
    clear_stale_celery_tasks()
    verify_celery_queues()
    print_summary(cfg)


# ── Usage ─────────────────────────────────────────────────────────────────────

def _usage():
    print("""
  foctl — Citadel deployment CLI

  Usage:  ./foctl <command> [args]

  DEPLOY
    deploy docker               Docker Compose — builds images, starts all services
    deploy k8s   [flags]        Deploy to the current kubectl context
    deploy k8s-new [flags]      Create a local k3d cluster then deploy

  Kubernetes deploy flags:
    --no-build                  Skip Docker image rebuild (re-apply manifests only)
    --no-cache                  Force full Docker rebuild (ignore layer cache)
    --restart                   Re-apply manifests + restart pods, skip build + load
    --setup-traefik             Also apply kube-system Traefik config (first deploy only)
                                WARNING: restarts Traefik, breaks Tailscale DNS until re-applied

  OPERATIONS  (mode auto-detected if omitted)
    status  [docker|k8s]        Service / pod health overview
    logs    <svc> [mode]        Stream logs — api | processor | frontend | all
    update  [docker|k8s]        Rebuild images + redeploy
    destroy [docker|k8s]        Remove all services and data (confirms first)
    config                      Show parsed config.json + redacted .env
""")


# ── Main ──────────────────────────────────────────────────────────────────────

CHART = ROOT / "charts" / "citadel"


def deploy_helm(cfg, no_build=False, no_cache=False):
    """Deploy via the Helm umbrella chart (charts/citadel).

    The chart is app-only (api/processor/frontend) by design — substrate
    (Elasticsearch/Redis/MinIO) is "bring your own": point config.json's
    `substrate` block at existing/external services. Reuses build_images /
    load_images, so image build + cluster import work exactly like the k8s mode.
    """
    if not cmd_exists("helm"):
        die("helm not found. Install Helm 3, or use './foctl deploy k8s'.")
    if not cluster_reachable():
        die("No reachable cluster (check kubectl context/kubeconfig).")

    if not no_build:
        build_images(cfg, no_cache=no_cache)
    load_images(cfg)   # imports images into the cluster runtime (k3s/k3d/…)

    reg      = cfg["images"]["registry"].rstrip("/")
    registry = f"{reg}/" if reg else ""
    tag      = cfg["images"]["tag"]
    sub      = cfg.get("substrate", {})
    sec      = cfg.get("secrets", {})
    acc      = cfg.get("access", {})
    release  = cfg.get("release", "citadel")

    # String values → --set-string (URLs/repos must not be type-coerced).
    str_sets = {
        "global.image.registry":        registry,
        "global.image.tag":             tag,
        "global.image.pullPolicy":      "IfNotPresent",
        "api.image.repository":         "forensics-operator/api",
        "processor.image.repository":   "forensics-operator/processor",
        "frontend.image.repository":    "forensics-operator/frontend",
        "config.elasticsearchUrl":      sub.get("elasticsearch_url", "http://elasticsearch:9200"),
        "config.redisUrl":              sub.get("redis_url", "redis://redis-service:6379/0"),
        "config.minioEndpoint":         sub.get("minio_endpoint", "minio-service:9000"),
        "config.minioBucket":           sub.get("minio_bucket", "forensics-cases"),
        "secret.jwtSecret":             sec.get("jwt_secret", ""),
        "secret.minioAccessKey":        sec.get("minio_access_key", "minioadmin"),
        "secret.minioSecretKey":        sec.get("minio_secret_key", "minioadmin"),
        "secret.authEnabled":           str(cfg.get("auth", {}).get("auth_enabled", True)).lower(),
    }
    # Booleans → --set (a string "false" would be truthy in the templates).
    bool_sets = {}
    if acc.get("hostname"):
        bool_sets["ingress.enabled"] = "true"
        str_sets["ingress.fqdn"]      = acc["hostname"]
        ing_class = acc.get("ingress_class", "traefik")
        str_sets["ingress.className"] = ing_class
        if ing_class != "traefik":
            bool_sets["ingress.tls.enabled"] = "false"   # tailscale/nginx terminate TLS themselves

    # Size requests/limits from the real host (admin cap + headroom in
    # config/resources.yaml) → emits charts/citadel/values-resources.generated.yaml
    overlay = CHART / "values-resources.generated.yaml"
    step("Sizing resources from host (scripts/allocate_resources.py)")
    run([sys.executable, str(ROOT / "scripts" / "allocate_resources.py")], check=False)

    cmd = ["helm", "upgrade", "--install", release, str(CHART),
           "-n", NS, "--create-namespace"]
    if overlay.exists():
        cmd += ["-f", str(overlay)]
    for k, v in str_sets.items():
        cmd += ["--set-string", f"{k}={v}"]
    for k, v in bool_sets.items():
        cmd += ["--set", f"{k}={v}"]

    step(f"helm upgrade --install {release} → namespace '{NS}'")
    run(cmd)
    ok(f"Helm release '{release}' applied to '{NS}'")
    info(f"Watch rollout:  kubectl -n {NS} get pods -w")
    if acc.get("hostname"):
        info(f"URL:            https://{acc['hostname']}/")


def cmd_destroy_helm(cfg):
    release = cfg.get("release", "citadel")
    if input(f"  Uninstall helm release '{release}' from '{NS}'? [y/N] ").strip().lower() != "y":
        info("Aborted."); return
    run(["helm", "uninstall", release, "-n", NS], check=False)
    ok("Helm release uninstalled (substrate in other namespaces untouched).")


def cmd_status_helm(cfg):
    release = cfg.get("release", "citadel")
    run(["helm", "status", release, "-n", NS], check=False)
    run(["kubectl", "-n", NS, "get", "pods,svc,ingress"], check=False)


def main():
    args = sys.argv[1:]

    if not args:
        _menu()
        return

    cmd  = args[0]
    rest = args[1:]

    if cmd in ("help", "-h", "--help"):
        _usage()
        return

    if cmd == "deploy":
        if not rest:
            die("Usage: ./foctl deploy <docker|k8s|k8s-new>")
        mode  = rest[0]
        flags = rest[1:]

        if mode == "docker":
            deploy_docker()

        elif mode == "helm":
            ensure_secrets()
            cfg = load_config()
            deploy_helm(cfg,
                        no_build="--no-build" in flags,
                        no_cache="--no-cache" in flags)

        elif mode in ("k8s", "k8s-new"):
            no_build      = "--no-build"      in flags or "--restart" in flags
            no_cache      = "--no-cache"      in flags
            restart       = "--restart"       in flags
            setup_traefik = "--setup-traefik" in flags

            ensure_secrets()
            cfg = load_config()
            if mode == "k8s-new":
                ensure_k3d()
                create_k3d_cluster(cfg)

            _deploy_k8s_flow(cfg, no_build=no_build, no_cache=no_cache,
                             restart=restart, setup_traefik=setup_traefik)
        else:
            die(f"Unknown deploy mode '{mode}'. Choose one of: docker, helm, k8s, k8s-new")

    elif cmd == "status":
        mode = rest[0] if rest else ""
        load_config()
        if not mode:
            mode = _detect_mode()
        if not mode:
            die("No active deployment detected. Pass 'docker' or 'k8s' explicitly.")
        if mode == "docker":
            cmd_status_docker()
        elif mode == "k8s":
            cmd_status_k8s()
        else:
            die(f"Unknown mode '{mode}'")

    elif cmd == "logs":
        svc  = rest[0] if rest else "api"
        mode = rest[1] if len(rest) > 1 else ""
        load_config()
        if not mode:
            mode = _detect_mode()
        if not mode:
            die("No active deployment detected. Pass mode explicitly.")
        if mode == "docker":
            cmd_logs_docker(svc)
        elif mode == "k8s":
            if svc == "all":
                procs = [
                    subprocess.Popen(["kubectl", "logs", "-n", NS,
                                      "-l", f"app={s}", "-f", "--tail=50"])
                    for s in ["api", "processor"]
                ]
                try:
                    for p in procs:
                        p.wait()
                except KeyboardInterrupt:
                    for p in procs:
                        p.terminate()
            else:
                cmd_logs_k8s(svc)
        else:
            die(f"Unknown mode '{mode}'")

    elif cmd == "update":
        mode = rest[0] if rest else ""
        if not mode:
            load_config()
            mode = _detect_mode()
        if not mode:
            die("No active deployment detected. Pass mode explicitly.")
        if mode == "docker":
            cmd_update_docker()
        elif mode == "k8s":
            cfg = load_config()
            _deploy_k8s_flow(cfg)
        else:
            die(f"Unknown mode '{mode}'")

    elif cmd == "destroy":
        mode = rest[0] if rest else ""
        if not mode:
            load_config()
            mode = _detect_mode()
        if not mode:
            die("No active deployment detected. Pass mode explicitly.")
        if mode == "docker":
            cmd_destroy_docker()
        elif mode == "k8s":
            cfg = load_config()
            cmd_destroy_k8s(cfg)
        elif mode == "helm":
            cmd_destroy_helm(load_config())
        else:
            die(f"Unknown mode '{mode}'")

    elif cmd == "config":
        cmd_config()

    else:
        die(f"Unknown command '{cmd}'. Run ./foctl --help for usage.")


if __name__ == "__main__":
    main()
