        return
    ok("Template applied")
    # Backfill: ES templates apply at index creation. Existing fo-case-* indices
    # use the original dynamic mapping. Aliases can be added to live mappings —
    # but ES requires the alias target field to exist in that index, so a single
    # wildcard PUT fails. We pass the alias spec into a single in-pod Python
    # script that iterates indices server-side and applies matching aliases.
    backfill_aliases_in_pod(tmpl)


# In-pod alias back-fill runs entirely inside one kubectl exec (avoids spawning
# hundreds of kubectl calls over SSH, which gets killed by the connection).
_BACKFILL_PY = r"""
import json, sys, urllib.request, urllib.error

aliases = json.loads(sys.stdin.read())  # {name: {type:alias, path:dotted}}
if not aliases:
    print('NO_ALIASES'); sys.exit(0)

def es(method, path, body=None):
    req = urllib.request.Request(
        'http://elasticsearch:9200' + path, method=method,
        data=(json.dumps(body).encode() if body else None),
        headers={'Content-Type': 'application/json'} if body else {},
    )
    try:
        with urllib.request.urlopen(req, timeout=15) as r:
            return r.status, json.loads(r.read() or b'{}')
    except urllib.error.HTTPError as e:
        return e.code, json.loads((e.read() or b'{}'))
    except Exception as e:
        return 0, {'error': str(e)}

st, j = es('GET', '/_cat/indices/fo-case-*?h=index&format=json')
if st != 200:
    print('LIST_FAIL', st); sys.exit(1)
indices = sorted(row['index'] for row in j)
applied = skipped = errored = 0
for idx in indices:
    st, mp = es('GET', f'/{idx}/_mapping/field/*')
    if st != 200: errored += 1; continue
    existing = set(mp.get(idx, {}).get('mappings', {}).keys())
    valid = {n: s for n, s in aliases.items()
             if s.get('path') in existing and n not in existing}
    if not valid: skipped += 1; continue
    # Raise the per-index field limit; aliases count toward total_fields.limit
    # and existing indices may already be at the cap (template default = 2000).
    es('PUT', f'/{idx}/_settings', {'index.mapping.total_fields.limit': 2200})
    st2, body = es('PUT', f'/{idx}/_mapping', {'properties': valid})
    if 200 <= st2 < 300: applied += 1
    else:
        errored += 1
        print(f'FAIL {idx} {st2} {json.dumps(body)[:160]}', flush=True)
print(f'RESULT applied={applied} skipped={skipped} errored={errored}')
"""


def backfill_aliases_in_pod(tmpl):
    try:
        import json as _json
        spec = _json.loads(tmpl.read_text())
        props = spec.get("template", {}).get("mappings", {}).get("properties", {}) or {}
        aliases = {k: v for k, v in props.items()
                   if isinstance(v, dict) and v.get("type") == "alias"}
        if not aliases:
            return
        step(f"Back-filling {len(aliases)} aliases on existing fo-case-* indices")
        # Pick a pod that has python — the api pod always does.
        r_pod = run(["kubectl", "get", "pod", "-n", NS, "-l", "app=api",
                     "-o", "jsonpath={.items[0].metadata.name}"],
                    capture=True, check=False)
        pod = (r_pod.stdout or "").strip()
        if not pod:
            warn("No api pod found — alias back-fill skipped")
            return
        r = run(["kubectl", "exec", "-n", NS, "-i", pod, "--",
                 "python3", "-c", _BACKFILL_PY],
                stdin_text=_json.dumps(aliases), capture=True, check=False)
        out = (r.stdout or "").strip()
        if "RESULT" in out:
            ok(f"Alias back-fill — {out.splitlines()[-1]}")
        else:
            warn(f"Alias back-fill output: {out or r.stderr.strip()}")
    except Exception as exc:  # pragma: no cover
        warn(f"Alias back-fill skipped: {exc}")


