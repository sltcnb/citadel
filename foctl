# ── Terminal colours ──────────────────────────────────────────────────────────

if sys.stdout.isatty():
    RED    = '\033[0;31m'
    GREEN  = '\033[0;32m'
    YELLOW = '\033[1;33m'
    CYAN   = '\033[0;36m'
    BOLD   = '\033[1m'
    RESET  = '\033[0m'
else:
    RED = GREEN = YELLOW = CYAN = BOLD = RESET = ''

def step(msg): print(f"\n{CYAN}→{RESET} {BOLD}{msg}{RESET}")
def ok(msg):   print(f"  {GREEN}✓{RESET}  {msg}")
def warn(msg): print(f"  {YELLOW}⚠{RESET}   {msg}")
def info(msg): print(f"     {msg}")
def die(msg):  print(f"\n  {RED}✗  ERROR:{RESET} {msg}\n", file=sys.stderr); sys.exit(1)


def run(cmd, capture=False, check=True, stdin_text=None, shell=False):
    if not capture and not shell:
        info("$ " + " ".join(str(c) for c in cmd))
    result = subprocess.run(
        cmd, capture_output=capture, text=True, check=False,
        input=stdin_text, shell=shell,
    )
    if check and result.returncode != 0:
        if capture:
            print(result.stderr or result.stdout or "(no output)")
        die(f"Command failed (exit {result.returncode})")
    return result


def cmd_exists(name): return shutil.which(name) is not None


# ── Docker Compose helpers ────────────────────────────────────────────────────

def dc_cmd():
    r = subprocess.run(["docker", "compose", "version"], capture_output=True, text=True)
    if r.returncode == 0:
        return ["docker", "compose"]
    if cmd_exists("docker-compose"):
        return ["docker-compose"]
    die("Neither 'docker compose' (v2) nor 'docker-compose' (v1) found.\n"
        "  Install Docker Desktop or the Docker Compose plugin.")


# ── Config ────────────────────────────────────────────────────────────────────

def load_config():
    path = ROOT / "config.json"
    if not path.exists():
        die("config.json not found. Run this script from the citadel directory.")
    with open(path) as f:
        raw = json.load(f)

    def clean(d):
        if isinstance(d, dict):
            return {k: clean(v) for k, v in d.items() if not k.startswith("_")}
        return d

    cfg = clean(raw)
    global NS
    NS = cfg.get("namespace", "forensics-operator")
    return cfg


_PLACEHOLDERS = {"", "CHANGE_ME", "CHANGE_ME_IN_PRODUCTION"}
SECRET_GENERATORS = {
    "minio_access_key": lambda: "citadel-" + _secrets.token_hex(8),
    "minio_secret_key": lambda: _secrets.token_urlsafe(32),
    "jwt_secret":       lambda: _secrets.token_hex(32),
    "admin_password":   lambda: _secrets.token_urlsafe(12),
}


def ensure_secrets():
    """Generate any missing/placeholder secrets in config.json on first deploy.

    Values are written back to config.json (preserving comments) so they stay
    STABLE across redeploys — a regenerated jwt_secret would log everyone out,
    and changed MinIO keys would orphan stored artifacts. Returns the dict of
    freshly generated secrets so the caller can surface the admin password once.
    """
    path = ROOT / "config.json"
    if not path.exists():
        die("config.json not found. Copy config.json.example to config.json first.")
    raw = json.load(open(path))
    sec = raw.setdefault("secrets", {})
    generated = {}
    for key, gen in SECRET_GENERATORS.items():
        cur = sec.get(key)
        if cur is None or str(cur).strip() in _PLACEHOLDERS:
            sec[key] = gen()
            generated[key] = sec[key]
    sec.setdefault("admin_username", "admin")
    if generated:
        with open(path, "w") as f:
            json.dump(raw, f, indent=2)
            f.write("\n")
        step("Generated secrets → saved to config.json (stable across redeploys)")
        for k in sorted(generated):
            if k == "admin_password":
                warn(f"admin password: {GREEN}{generated[k]}{RESET}  ← save it; change after first login")
            else:
                ok(f"{k}: generated")
    return generated


def image_name(svc, cfg):
    reg = cfg["images"]["registry"].rstrip("/")
    prefix = f"{reg}/" if reg else ""
    return f"{prefix}forensics-operator/{svc}:{cfg['images']['tag']}"


def _mib(s, default):
    """'1234Mi'/'2Gi' -> int MiB; falls back to default."""
    try:
        s = str(s).strip()
        if s.endswith("Gi"):
            return int(float(s[:-2]) * 1024)
        if s.endswith("Mi"):
            return int(float(s[:-2]))
        return int(float(s))
    except Exception:
        return default


def auto_resources():
    """Host-aware resource plan for the k8s (raw-manifest) path, derived from the
    SAME allocator used by helm mode (config/resources.yaml: max_pct_of_host +
    headroom + per-service weights). Returns a dict in build_substitutions' shape,
    or {} on any failure (callers then fall back to static defaults).

    NOTE: sizing is off TOTAL host RAM/CPU — on a shared/loaded node set
    max_pct_of_host low in config/resources.yaml so Citadel doesn't over-commit.
    """
    try:
        import yaml
        sys.path.insert(0, str(ROOT / "scripts"))
        import allocate_resources as alloc
        cfg_y = yaml.safe_load((ROOT / "config" / "resources.yaml").read_text())
        plan, extra = alloc.allocate(cfg_y)
        st = extra["storage"]

        def rq(svc, kind, axis):       # plan[svc][requests|limits][cpu|memory]
            return plan[svc][kind][axis]

        es_lim_mib = _mib(rq("elasticsearch", "limits", "memory"), 1024)
        return {
            "api_memory_request": rq("api", "requests", "memory"),
            "api_memory_limit":   rq("api", "limits", "memory"),
            "api_cpu_request":    rq("api", "requests", "cpu"),
            "api_cpu_limit":      rq("api", "limits", "cpu"),
            "processor_memory_request": rq("processor", "requests", "memory"),
            "processor_memory_limit":   rq("processor", "limits", "memory"),
            "processor_cpu_request":    rq("processor", "requests", "cpu"),
            "processor_cpu_limit":      rq("processor", "limits", "cpu"),
            "frontend_memory_request":  rq("frontend", "requests", "memory"),
            "frontend_memory_limit":    rq("frontend", "limits", "memory"),
            "frontend_cpu_request":     rq("frontend", "requests", "cpu"),
            "frontend_cpu_limit":       rq("frontend", "limits", "cpu"),
            "minio_memory_request": rq("minio", "requests", "memory"),
            "minio_memory_limit":   rq("minio", "limits", "memory"),
            "minio_cpu_request":    rq("minio", "requests", "cpu"),
            "minio_cpu_limit":      rq("minio", "limits", "cpu"),
            # ES heap ≈ half the container limit (leave headroom for off-heap).
            "elasticsearch_heap_mb": max(256, es_lim_mib // 2),
            "elasticsearch_storage_gi": int(float(str(st.get("elasticsearch", "20Gi")).rstrip("Gi"))),
            "minio_storage_gi":         int(float(str(st.get("minio", "30Gi")).rstrip("Gi"))),
            "redis_storage_gi":         int(float(str(st.get("redis", "10Gi")).rstrip("Gi"))),
        }
    except Exception as exc:
        warn(f"auto resource sizing unavailable ({exc}); using defaults")
        return {}


def build_substitutions(cfg, pull_policy):
    # Resources: host-aware auto-allocation by default; an explicit "resources"
    # block in config.json overrides per-key; static defaults backstop both.
    res     = {**auto_resources(), **cfg.get("resources", {})}
    es_heap = res.get("elasticsearch_heap_mb", 512)
    auth    = cfg.get("auth", {})
    return {
        "__FO_NAMESPACE__":        NS,
        "__FO_API_IMAGE__":        image_name("api",       cfg),
        "__FO_PROCESSOR_IMAGE__":  image_name("processor", cfg),
        "__FO_FRONTEND_IMAGE__":   image_name("frontend",  cfg),
        "__FO_PULL_POLICY__":      pull_policy,
        "__FO_MINIO_ACCESS_KEY__": cfg.get("secrets", {}).get("minio_access_key", "minioadmin"),
