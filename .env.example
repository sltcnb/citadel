# ══════════════════════════════════════════════════════════════════════════════
# Citadel — environment configuration
# Copy this file to .env and fill in your values.
# All variables have sane defaults except JWT_SECRET and MINIO_SECRET_KEY.
# ══════════════════════════════════════════════════════════════════════════════

# ── Authentication (REQUIRED) ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Token lifetime in hours (default: 8)
JWT_EXPIRE_HOURS=8

# Disable to allow unauthenticated access (dev/trusted-LAN only)
AUTH_ENABLED=true

# ── MinIO object storage ───────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
# Use a strong password in production
MINIO_SECRET_KEY=minioadmin

# ── Elasticsearch ─────────────────────────────────────────────────────────────
# JVM heap per node. Set to ~50% of available RAM, max 31g.
# Example: 2g for a 4GB node, 8g for a 16GB node.
ES_HEAP_SIZE=1g

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis maxmemory cap. Raise if you process many large cases in parallel.
REDIS_MAXMEM=2gb

# ── API ───────────────────────────────────────────────────────────────────────
# Number of Uvicorn worker processes (async I/O bound — 4 is a good baseline)
API_WORKERS=4

# ── Celery workers ────────────────────────────────────────────────────────────
# Parallel ingest tasks per worker (I/O-bound: MinIO download + ES writes)
INGEST_CONCURRENCY=4

# Parallel module tasks per worker (CPU-bound: Hayabusa, Volatility3, YARA)
# Keep this low (2-4) to avoid OOM when running heavy analysis binaries.
MODULE_CONCURRENCY=2

# Tasks per child process before recycling (guards against memory leaks in
# Python plugins that process large forensic files)
WORKER_MAX_TASKS=50

# Elasticsearch bulk indexing batch size (higher = fewer round trips, more RAM)
BULK_SIZE=1000

# ── Reverse proxy / multi-app servers ────────────────────────────────────────
# If you already have nginx/Caddy/HAProxy in front and this server runs other
# Docker services, move Citadel off port 80 so there is no conflict.
# Example: set PROXY_PORT=8090 and point your upstream proxy to localhost:8090
# Leave at 80 if Citadel is the only thing on this machine.
PROXY_PORT=80

# ── Public URL ────────────────────────────────────────────────────────────────
# Set to the address users will reach this server at — used to generate
# the PowerShell collector download URL on the Collector page.
# Docker: http://<host-ip>   |   K8s: https://your-domain.com
FO_PUBLIC_URL=http://localhost
